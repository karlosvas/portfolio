---
import Layout from "@/layouts/IndexLayout.astro";
import Header from "@/layouts/Header.astro";
import Footer from "@/layouts/Footer.astro";
import Main from "@/layouts/Main.astro";
import type { I18nTranslations } from "@/../types/types";

// Select locale using i18n
import { getI18N } from "../../i18n/index";
let { currentLocale } = Astro;

// Get translation data for the selected locale
const data: I18nTranslations = getI18N({ currentLocale });
---

<Layout title="Portfolio Carlos Raul Vásquez Sánchez" , language={currentLocale}>
  <!-- Header -->
  <Header data={data} />
  <!-- Contenido principal -->
  <Main data={data} />
  <!-- Footer -->
  <Footer data={data} />
</Layout>

---
import type { I18nTranslations } from "@/../types/types";
const data: I18nTranslations = Astro.props.data;
---

<div class="absolute left-10">
  <button
    id="hamburgerBtn"
    type="button"
    class="transition-colors inline-flex h-10 w-10 items-center justify-center rounded-md duration-200 hover:text-purplePal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purplePal focus-visible:ring-offset-2 sm:hidden"
    aria-label="Abrir menu de navegacion"
    aria-controls="hamburgerModal"
    aria-expanded="false"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
    </svg>
  </button>

  <dialog
    id="hamburgerModal"
    class="fixed left-0 z-50 m-0 h-full w-80 border-none bg-whitePal p-0 text-blackPal backdrop:bg-blackPal backdrop:bg-opacity-50 dark:bg-blackPal dark:text-whitePal"
  >
    <div class="h-full overflow-hidden">
      <ul class="mt-10 flex h-full flex-col items-center justify-start">
        <li class="nav-item my-2 text-lg">
          <a
            href="#profile"
            class="transition-colors block px-4 py-2 duration-200 hover:text-purplePal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purplePal focus-visible:ring-offset-2"
          >
            {data.profile.title}
          </a>
        </li>
        <li class="nav-item my-2 text-lg">
          <a
            href="#projects"
            class="transition-colors block px-4 py-2 duration-200 hover:text-purplePal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purplePal focus-visible:ring-offset-2"
          >
            {data.projects.title}
          </a>
        </li>
        <li class="nav-item my-2 text-lg">
          <a
            href="#experiencie"
            class="transition-colors block px-4 py-2 duration-200 hover:text-purplePal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purplePal focus-visible:ring-offset-2"
          >
            {data.experience.title}
          </a>
        </li>
        <li class="nav-item my-2 text-lg">
          <a
            href="#contact"
            class="transition-colors block px-4 py-2 duration-200 hover:text-purplePal focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purplePal focus-visible:ring-offset-2"
          >
            {data.contact.title}
          </a>
        </li>
      </ul>
    </div>
  </dialog>
</div>

<style>
  #hamburgerModal {
    top: 10dvh;
    transition: top 0.3s;
  }

  #hamburgerModal.scrolled {
    top: 8dvh;
  }

  @keyframes slideDown {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(0);
    }
  }

  @keyframes slideUp {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-100%);
    }
  }

  @keyframes bgDown {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes bgUp {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  #hamburgerModal::backdrop {
    animation: bgDown 0.3s ease-in-out forwards;
  }

  #hamburgerModal.closing::backdrop {
    animation: bgUp 0.3s ease-in-out forwards;
  }

  #hamburgerModal[open] {
    animation: slideDown 0.3s ease-in-out forwards;
  }

  #hamburgerModal.closing {
    animation: slideUp 0.3s ease-in-out forwards;
  }
</style>

<script>
  function disableScroll() {
    // Save current scroll position
    const scrollY = globalThis.scrollY;
    // Calculate scrollbar width before locking
    const scrollbarWidth = globalThis.innerWidth - document.documentElement.clientWidth;
    // Store the position in a body data attribute
    document.body.dataset.scrollPosition = scrollY.toString();
    // Apply right padding equal to scrollbar width to avoid layout shift
    document.body.style.paddingRight = `${scrollbarWidth}px`;
    document.body.style.position = "fixed";
    document.body.style.top = `-${scrollY}px`;
    document.body.style.width = "100%";
    document.body.style.overflow = "hidden";
  }

  // Restore page scroll
  function enableScroll() {
    const scrollY = document.body.style.top;
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.width = "";
    document.body.style.paddingRight = ""; // Remove padding
    document.body.style.overflow = "";
    // Read saved position and restore it
    const savedPosition = parseInt(scrollY || "0") * -1;
    globalThis.scrollTo({
      top: savedPosition,
      behavior: "instant",
    });
  }

  // EVENTS
  const hamburgerBtn = document.getElementById("hamburgerBtn") as HTMLButtonElement | null;
  const hamburgerModal = document.getElementById("hamburgerModal") as HTMLDialogElement | null;
  let lastFocusedElement: HTMLElement | null = null;

  function closeModalWithAnimation() {
    if (hamburgerModal) {
      // Re-enable scrolling so section navigation works
      enableScroll();

      // Add class for close animation
      hamburgerModal.classList.add("closing");

      // Wait for animation to finish before closing modal
      setTimeout(() => {
        hamburgerModal.close();
        hamburgerModal.classList.remove("closing");
        hamburgerBtn?.setAttribute("aria-expanded", "false");
        (lastFocusedElement ?? hamburgerBtn)?.focus();
        // Body scroll is already restored
      }, 300); // Same duration as the animation (0.3s)
    }
  }

  // Open modal on hamburger button click
  hamburgerBtn?.addEventListener("click", () => {
    if (hamburgerModal) {
      lastFocusedElement = document.activeElement as HTMLElement;
      hamburgerModal.showModal();
      hamburgerBtn.setAttribute("aria-expanded", "true");
      // Prevent body scroll while modal is open
      disableScroll();

      // Move focus inside the menu for keyboard users
      const firstLink = hamburgerModal.querySelector<HTMLAnchorElement>(".nav-item a");
      firstLink?.focus();
    }
  });

  // Close modal with Escape key
  hamburgerModal?.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      event.preventDefault();
      closeModalWithAnimation();
    }
  });

  // Close modal when clicking outside
  hamburgerModal?.addEventListener("click", (event) => {
    // Close only when clicking outside modal content
    const rect = hamburgerModal.getBoundingClientRect();
    // Check whether click is inside dialog bounds
    const isInDialog =
      rect.top <= event.clientY &&
      event.clientY <= rect.top + rect.height &&
      rect.left <= event.clientX &&
      event.clientX <= rect.left + rect.width;
    // If click is outside, close modal
    if (!isInDialog) closeModalWithAnimation();
  });

  // Close modal when clicking a link inside it
  document.querySelectorAll(".nav-item a").forEach((item) => {
    item.addEventListener("click", (event) => {
      const targetId = item.getAttribute("href");

      if (targetId === null) return;

      closeModalWithAnimation();

      // Smoothly scroll to the target section
      const targetElement = document.querySelector(targetId);
      if (targetElement) {
        event.preventDefault();
        targetElement.scrollIntoView({ behavior: "smooth" });
      }
    });
  });
</script>

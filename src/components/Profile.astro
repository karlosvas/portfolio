---
import type { I18nTranslations } from "@/../types/types";
const data: I18nTranslations = Astro.props.data;

const birthDate = new Date(2004, 3, 13);
const today = new Date();
const age =
  today.getFullYear() -
  birthDate.getFullYear() -
  (today < new Date(today.getFullYear(), birthDate.getMonth(), birthDate.getDate()) ? 1 : 0);

const ageWords: Record<number, string> = {
  21: "veintiún",
  22: "veintidós",
  23: "veintitrés",
  24: "veinticuatro",
  25: "veinticinco",
  26: "veintiséis",
  27: "veintisiete",
  28: "veintiocho",
  29: "veintinueve",
};

const ageWordsEnglish: Record<number, string> = {
  21: "twenty-one",
  22: "twenty-two",
  23: "twenty-three",
  24: "twenty-four",
  25: "twenty-five",
  26: "twenty-six",
  27: "twenty-seven",
  28: "twenty-eight",
  29: "twenty-nine",
};

const ageLabel = data.profile.presentation.v1.includes("{age}")
  ? (ageWordsEnglish[age] ?? age.toString())
  : (ageWords[age] ?? age.toString());
---

<div
  id="profile"
  class="grid min-h-[90dvh] items-center justify-center gap-8 px-4 py-10 sm:grid-cols-2 md:w-3/4 lg:w-1/2"
>
  <!-- Img Profile -->
  <img
    class="m-auto w-full max-w-[260px] select-none rounded-lg object-cover sm:max-w-[320px] md:max-w-[360px] lg:my-0 lg:max-w-[380px] xl:max-w-[420px]"
    src="/img/profile.webp"
    alt="Imagen de perfil Carlos Vásquez Sánchez"
  />

  <!-- Info Profile -->
  <section class="flex flex-col justify-center space-y-4">
    <!-- Name -->
    <div class="space-y-2">
      <h1
        id="title"
        class="bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 bg-clip-text text-4xl font-bold text-transparent lg:min-h-10"
      >
        {" "}
      </h1>
      <p class="text-lg font-semibold text-purplePal/80 md:text-xl">{data.profile.subtitle}</p>
    </div>
    <!-- Info -->
    <div class="space-y-4 text-base leading-relaxed md:text-base">
      <p class="transition-opacity text-pretty opacity-90 duration-300 hover:opacity-100">
        {data.profile.presentation.v1.replace("{age}", ageLabel)}
      </p>
      <p class="transition-opacity text-pretty opacity-90 duration-300 hover:opacity-100">
        {data.profile.presentation.v2}
      </p>
    </div>
  </section>
</div>
<script is:inline define:vars={{ data }}>
  // Update title with a typing effect
  async function updateTitle(name) {
    const title = document.getElementById("title");

    if (title) {
      title.innerHTML = "";
      title.style.minHeight = "5rem";

      // Create a container for the text
      const textSpan = document.createElement("span");
      textSpan.style.whiteSpace = "pre-line";

      // Create the cursor span and assign the blinking-cursor class
      const cursorSpan = document.createElement("span");
      cursorSpan.innerText = "|";
      cursorSpan.classList.add("blinking-cursor");
      cursorSpan.style.display = "inline-block";
      cursorSpan.style.width = "0.5em";

      title.appendChild(textSpan);
      title.appendChild(cursorSpan);

      // Iterate through each letter and simulate a typing effect
      let result = "";
      for (let i = 0; i < name.length; i++) {
        await new Promise((resolve) => setTimeout(resolve, 100));
        result += name[i];
        if (result === "Carlos Raúl") result += "\n";
        textSpan.textContent = result;
      }

      // At the end, keep the cursor blinking and then remove it
      cursorSpan.style.animation = "blink 1s infinite";
      setTimeout(() => {
        cursorSpan.remove();
      }, 3000);
    }
  }

  globalThis.addEventListener("DOMContentLoaded", () => updateTitle(data.profile.name));
</script>
<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
  }
</style>

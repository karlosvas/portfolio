---
import type { I18nTranslations } from "@/../types/types";
import ButtonCustomized from "./ButtonCustomized.astro";

const data: I18nTranslations = Astro.props.data;
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<!-- Script de Turnstile -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"></script>

<!-- Contacto -->
<div class="mb-32 w-full max-w-2xl px-2 sm:px-4">
  <h1 id="contact" class="text-darkPal mb-8 text-center text-3xl font-bold dark:text-whitePal md:text-4xl">
    {data.contact.title}
  </h1>

  <form
    class="flex w-full flex-col gap-6 rounded-2xl border border-purple-500/10 bg-gradient-to-br from-purple-500/5 to-blue-500/5 p-6 shadow-xl backdrop-blur-sm md:p-8"
    id="formEmail"
  >
    <div class="group flex flex-col gap-3">
      <label
        for="email"
        class="transition-colors text-sm font-semibold duration-300 group-focus-within:text-purplePal md:text-base"
      >
        {data.contact.formEmail}
      </label>
      <input
        id="email"
        name="email"
        type="email"
        placeholder={data.contact.placeholders.email}
        class="transition-all rounded-lg border-2 border-gray-700/40 bg-gray-900/80 p-3 text-white duration-300 placeholder:text-gray-400 focus:border-purplePal focus:outline-none focus:ring-2 focus:ring-purplePal/20 dark:border-gray-400/40 dark:bg-white/90 dark:text-black dark:placeholder:text-gray-500 md:p-4"
      />
    </div>

    <div class="group flex flex-col gap-3">
      <label
        for="mensaje"
        class="transition-colors text-sm font-semibold duration-300 group-focus-within:text-purplePal md:text-base"
      >
        {data.contact.formMessage}
      </label>
      <textarea
        id="mensaje"
        name="mensaje"
        rows="5"
        placeholder={data.contact.placeholders.message}
        class="transition-all resize-none rounded-lg border-2 border-gray-700/40 bg-gray-900/80 p-3 text-white duration-300 placeholder:text-gray-400 focus:border-purplePal focus:outline-none focus:ring-2 focus:ring-purplePal/20 dark:border-gray-400/40 dark:bg-white/90 dark:text-black dark:placeholder:text-gray-500 md:p-4"
      ></textarea>
    </div>

    <!-- Cloudflare Turnstile Widget -->
    {TURNSTILE_SITE_KEY && <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-size="invisible" />}

    <ButtonCustomized>
      {data.contact.formSubmit}
    </ButtonCustomized>
  </form>
</div>

<script>
  import toast from "solid-toast";
  import { FormEnum, FormEnumEnglish } from "@/../types/formEnum.ts";

  // ─── Constants ────────────────────────────────────────────────────────────
  const TURNSTILE_TIMEOUT_MS = 10_000;
  const form = document.getElementById("formEmail") as HTMLFormElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const formEnum = document.documentElement.lang === "es" ? FormEnum : FormEnumEnglish;
  const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

  // ─── Turnstile State ──────────────────────────────────────────────────────
  let widgetId: string | null = null;
  let resolveToken: ((token: string) => void) | null = null;
  let rejectToken: ((reason: unknown) => void) | null = null;

  // ─── Turnstile Init ───────────────────────────────────────────────────────
  widgetId = globalThis.turnstile.render(".cf-turnstile", {
    sitekey: turnstileKey,
    size: "invisible",
    execution: "execute",
    callback: (token: string) => {
      resolveToken?.(token);
      resolveToken = null;
      rejectToken = null;
    },
    "error-callback": () => {
      rejectToken?.(new Error(formEnum.MESSAGE_ERROR));
      resolveToken = null;
      rejectToken = null;
    },
  });

  // ─── Turnstile Token ──────────────────────────────────────────────────────
  function requestToken(): Promise<string> {
    return new Promise<string>((resolve, reject) => {
      const timeout = window.setTimeout(() => reject(new Error(formEnum.MESSAGE_ERROR)), TURNSTILE_TIMEOUT_MS);

      resolveToken = (token) => {
        clearTimeout(timeout);
        resolve(token);
      };
      rejectToken = (reason) => {
        clearTimeout(timeout);
        reject(reason);
      };

      globalThis.turnstile.execute(widgetId);
    });
  }

  // ─── Form Validation ──────────────────────────────────────────────────────
  function validateForm(): void {
    if (!form.email.value) throw new Error(formEnum.EMPTY_EMAIL);
    if (!form.mensaje.value) throw new Error(formEnum.EMPTY_MESSAGE);
  }

  // ─── API ──────────────────────────────────────────────────────────────────
  async function sendEmail(turnstileToken: string): Promise<void> {
    const response = await fetch("/api/resend", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        email: form.email.value,
        message: form.mensaje.value,
        turnstileToken,
      }),
    });

    if (!response.ok) throw new Error(formEnum.MESSAGE_ERROR);
  }

  // ─── Submit Handler ───────────────────────────────────────────────────────
  async function handleSubmit(e: Event): Promise<void> {
    e.preventDefault();
    if (submitButton) submitButton.disabled = true;

    const loadingToastId = toast.loading(formEnum.SENDING);

    try {
      validateForm();
      const token = await requestToken();
      await sendEmail(token);

      toast.success(formEnum.MESSAGE_SENT, { id: loadingToastId, duration: 3000 });
      form.reset();
      globalThis.turnstile?.reset(widgetId);
    } catch (error) {
      toast.error(formEnum.MESSAGE_ERROR, { id: loadingToastId, duration: 3000 });
      globalThis.turnstile?.reset(widgetId);
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
  }

  form?.addEventListener("submit", handleSubmit);
</script>
